# Provider selection
PROVIDER=ollama
MODEL=

# LM Studio
# For Dockerized app use: http://host.docker.internal:1234/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=

# Ollama
# For Dockerized app use: http://host.docker.internal:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=

# OpenTelemetry / OpenLit
# For Dockerized app/load-test use: http://otel-collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=llm-monitoring-demo
# Default in code is agno,openai (leave empty to use defaults, or set to "none" to enable all).
OPENLIT_DISABLED_INSTRUMENTORS=
OPENLIT_ALLOW_FAILURE=

# Observability stack (Grafana + Tempo + Loki + Prometheus) starts by default in docker compose.

# Load test (used by docker compose load-test-* services)
# To auto-enable profile: COMPOSE_PROFILES=loadtest-lmstudio or loadtest-ollama
LOADTEST_REQUESTS=20
LOADTEST_CONCURRENCY=5
LOADTEST_DELAY=0
LOADTEST_PROMPT=
LOADTEST_SYSTEM=
LOADTEST_TEMPERATURE=0.2
LOADTEST_MAX_TOKENS=128
